# Panel Blocks
items:
  wathe:golden_glass_panel:
    data:
      item-name: <!i><lang:block.wathe.golden_glass_panel>
    model: wathe:block/golden_glass_panel
    behavior:
      type: block_item
      block:
        behavior:
          type: trapdoor_block
          can-open-with-hand: false
          can-open-by-wind-charge: false
        loot:
          template: default:loot_table/self
        settings:
          hardness: 0.3
          resistance: 0.3
          map-color: 43
          is-suffocating: false
          is-redstone-conductor: false
          tags:
            - minecraft:mineable/pickaxe
          sounds:
            break: minecraft:block.glass.break
            fall: minecraft:block.glass.fall
            hit: minecraft:block.glass.hit
            place: minecraft:block.glass.place
            step: minecraft:block.glass.step
        states:
          properties:
            facing:
              type: horizontal_direction
              default: north
            half:
              type: single_block_half
              default: bottom
            open:
              type: boolean
              default: true
            powered:
              type: boolean
              default: false
          appearances:
            n_b:
              state: oak_trapdoor[facing=north,half=bottom,open=true]
              model:
                path: wathe:block/golden_glass_panel
            e_b:
              state: oak_trapdoor[facing=east,half=bottom,open=true]
              model:
                path: wathe:block/golden_glass_panel
                y: 90
            s_b:
              state: oak_trapdoor[facing=south,half=bottom,open=true]
              model:
                path: wathe:block/golden_glass_panel
                y: 180
            w_b:
              state: oak_trapdoor[facing=west,half=bottom,open=true]
              model:
                path: wathe:block/golden_glass_panel
                y: 270
          variants:
            facing=north,half=bottom,open=true:
              appearance: n_b
            facing=east,half=bottom,open=true:
              appearance: e_b
            facing=south,half=bottom,open=true:
              appearance: s_b
            facing=west,half=bottom,open=true:
              appearance: w_b

